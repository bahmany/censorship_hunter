# ═══════════════════════════════════════════════════════════════
# Hunter — .gitignore
# ═══════════════════════════════════════════════════════════════

# ─── OS Generated Files ──────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*~

# ─── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.sln.docstates

# ─── C++ Build Artifacts ────────────────────────────────────
hunter_cpp/build/
hunter_cpp/runtime/
*.o
*.obj
*.a
*.lib
*.pch
*.pdb
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# ─── Flutter Build Artifacts ─────────────────────────────────
hunter_flutter_ui/.dart_tool/
hunter_flutter_ui/.packages
hunter_flutter_ui/build/
hunter_flutter_ui/.flutter-plugins
hunter_flutter_ui/.flutter-plugins-dependencies
hunter_flutter_ui/pubspec.lock
hunter_flutter_ui/windows_installer_wix/
*.iml

# ─── Binaries & Proxy Engines (release-only) ────────────────
# These are large binaries shipped in GitHub Releases, not in source.
# Download from Releases or build from source.
bin/

# ─── Runtime Data ────────────────────────────────────────────
runtime/
HUNTER_*.json
HUNTER_*.txt

# ─── Config Caches (user/runtime data) ──────────────────────
config/All_Configs_Sub.txt
config/all_extracted_configs.txt
config/sub.txt
config/__pycache__/
config/import/processed/
*cache*.txt
subscriptions_cache.txt
working_configs_cache.txt

# ─── Release Packages ───────────────────────────────────────
*.zip
Hunter-Release/
Hunter-v*-*/
installer/output/

# ─── Secrets & Credentials ──────────────────────────────────
.env
*.env
!.env.example
*.session

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
