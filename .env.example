# ══════════════════════════════════════════════════════════════
# Hunter — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The C++ backend (hunter_cli) reads these at startup.
# WARNING: Never commit .env to version control!
# ══════════════════════════════════════════════════════════════

# ─── Telegram Bot (for publishing validated configs) ─────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
CHAT_ID=

# ─── Telegram Scraping (optional, configured via UI) ────────
# Get credentials from https://my.telegram.org/apps
# These can also be set in the Flutter UI Advanced tab.
# HUNTER_API_ID=
# HUNTER_API_HASH=
# HUNTER_PHONE=

# ─── Scanning & Validation ──────────────────────────────────
HUNTER_SCAN_LIMIT=50               # Configs per scan cycle
HUNTER_MAX_CONFIGS=1000            # Max configs in working set
HUNTER_WORKERS=10                  # Worker thread count
HUNTER_TEST_TIMEOUT=10             # Per-config test timeout (seconds)

# ─── Load Balancer ──────────────────────────────────────────
HUNTER_MULTIPROXY_PORT=10808       # Main SOCKS5 balancer port
HUNTER_MULTIPROXY_BACKENDS=20      # Max backends per balancer
HUNTER_GEMINI_PORT=10809           # Secondary balancer port

# ─── GitHub Background Fetch ────────────────────────────────
HUNTER_GITHUB_BG_CAP=150000        # Max configs from GitHub background fetch
HUNTER_GITHUB_BG_ENABLED=true      # Enable/disable GitHub background downloader

# ─── Continuous Validation ──────────────────────────────────
HUNTER_BG_VALIDATION_BATCH=120     # Background validation batch size
HUNTER_VALIDATOR_BATCH=80          # Continuous validator batch size

# ─── DPI Evasion ────────────────────────────────────────────
HUNTER_DPI_EVASION=true            # Enable adaptive DPI evasion
HUNTER_DPI_PRESSURE_INTENSITY=0.7  # Pressure engine intensity (0.1-1.0)
